{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es6",
        "noImplicitAny": false,
        "sourceMap": true,
        "rootDir": ".",
        "noEmitOnError": true,
        "typeRoots": [
            "../src/@custom_types",
            "../node_modules/@types"
        ],
        "types": [
            "node",
            "sketch"
        ]
